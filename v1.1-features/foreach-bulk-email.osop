osop_version: "1.1"
id: "foreach-bulk-email"
name: "Bulk Email Campaign with foreach"
description: "Demonstrates v1.1 foreach iteration — send personalized emails to a user list."
tags: [v1.1, foreach, loop, marketing]

nodes:
  - id: "fetch_subscribers"
    type: "db"
    purpose: "Query active subscribers from database."
    runtime:
      engine: "postgres"
      table: "subscribers"

  - id: "personalize"
    type: "agent"
    subtype: "llm"
    purpose: "Generate personalized email content for each subscriber."
    runtime:
      model: "claude-sonnet-4-6"

  - id: "send_email"
    type: "api"
    purpose: "Send email via SendGrid API."
    runtime:
      endpoint: "https://api.sendgrid.com/v3/mail/send"
      method: "POST"
    retry_policy:
      max_retries: 2
      strategy: "exponential_backoff"

  - id: "log_results"
    type: "data"
    purpose: "Record send status for analytics."

edges:
  - from: "fetch_subscribers"
    to: "personalize"
    mode: "loop"
    for_each: "outputs.fetch_subscribers.rows"
    iterator_var: "subscriber"
  - from: "personalize"
    to: "send_email"
    mode: "sequential"
  - from: "send_email"
    to: "log_results"
    mode: "sequential"
  - from: "send_email"
    to: "log_results"
    mode: "error"
    label: "Log failed sends too"
